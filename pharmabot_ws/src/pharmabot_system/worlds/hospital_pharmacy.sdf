          <material><ambient>0.96 0.96 0.96 1</ambient><diffuse>0.96 0.96 0.96 1</diffuse></material></visual>
      </link></model>
    <model name="bed_r3"><static>true</static><pose>7.2 7.5 0.35 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.85 1.95 0.7</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>0.85 1.95 0.7</size></box></geometry>
          <material><ambient>0.96 0.96 0.96 1</ambient><diffuse>0.96 0.96 0.96 1</diffuse></material></visual>
      </link></model>
    <model name="bed_r4"><static>true</static><pose>9.0 7.5 0.35 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.85 1.95 0.7</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>0.85 1.95 0.7</size></box></geometry>
          <material><ambient>0.96 0.96 0.96 1</ambient><diffuse>0.96 0.96 0.96 1</diffuse></material></visual>
      </link></model>
    <!-- 2 beds south room -->
    <model name="bed_r5"><static>true</static><pose>4.5 2.5 0.35 0 0 0</pose>
